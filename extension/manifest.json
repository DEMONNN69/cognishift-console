{
  "manifest_version": 3,
  "name": "CogniShift Notifier",
  "version": "1.0.0",
  "description": "Silently captures browser notifications and sends them to the CogniShift pipeline.",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/notification-patch.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content/whatsapp-observer.js"],
      "run_at": "document_end",
      "world": "ISOLATED",
      "all_frames": false
    }
  ]
}
